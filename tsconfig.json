{
	"compilerOptions": {
		"moduleResolution": "bundler",
		"module": "esnext",
		"target": "es2020",
		"strict": true,
		"types": ["node"],
		"removeComments": true,
		"stripInternal": true,
		"preserveConstEnums": true
	},
	"ts-node": {
		"compilerOptions": {
			"moduleResolution": "nodenext",
			"module": "nodenext"
		}
	},
	"include": ["./source/**/*", "./tests/**/*", "rollup.config.ts"]
}