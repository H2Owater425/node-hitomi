{
	"name": "node-hitomi",
	"version": "9.1.1",
	"description": "Hitomi.la API for Node.js",
	"keywords": [
		"hitomi",
		"e-hentai",
		"exhentai",
		"api",
		"downloader"
	],
	"homepage": "https://github.com/H2Owater425/node-hitomi#readme",
	"bugs": {
		"url": "https://github.com/h2owater425/node-hitomi/issues",
		"email": "h2o@dhmo.kr"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/h2owater425/node-hitomi.git"
	},
	"license": "MIT",
	"author": "H2Owater425 <h2o@dhmo.kr>",
	"exports": {
		".": {
			"types": "./distribution/types/index.d.ts",
			"browser": "./distribution/browser/index.js",
			"import": "./distribution/esm/index.mjs",
			"default": "./distribution/cjs/index.cjs"
		}
	},
	"main": "./distribution/cjs/index.cjs",
	"types": "./distribution/types/index.d.ts",
	"browser": "./distribution/browser/index.js",
	"scripts": {
		"build": "rollup --config=rollup.config.ts --configPlugin=@rollup/plugin-typescript",
		"dev": "node --require=tsconfig-paths/register --require=ts-node/register debug.ts",
		"test": "mocha --require=tsconfig-paths/register --require=ts-node/register tests/*.test.ts"
	},
	"devDependencies": {
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "~24",
		"mocha": "^10.8.2",
		"rollup": "^4.60.0",
		"rollup-plugin-dts": "^6.3.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"undici": "^8.3.0"
	},
	"peerDependencies": {
		"@types/node": ">=10.20"
	},
	"peerDependenciesMeta": {
		"@types/node": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=10.20"
	}
