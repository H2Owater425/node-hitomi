{
	"name": "node-hitomi",
	"version": "8.1.2",
	"description": "Hitomi.la api for Node.js",
	"main": "./distribution/cjs/index.cjs",
	"types": "./distribution/types/index.d.ts",
	"engines": {
		"node": ">=10.20"
	},
	"scripts": {
		"build": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
		"dev": "node --require=ts-node/register debug.ts",
		"test": "node --require=ts-node/register --test tests/*.test.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/h2owater425/node-hitomi.git"
	},
	"keywords": [
		"hitomi",
		"hitomi.la",
		"hentai"
	],
	"author": "H2Owater425 <h2o@dhmo.kr>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/h2owater425/node-hitomi/issues",
		"email": "h2o@dhmo.kr"
	},
	"homepage": "https://github.com/H2Owater425/node-hitomi#readme",
	"devDependencies": {
		"@rollup/plugin-commonjs": "^29.0.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"rollup": "^4.57.1",
		"rollup-plugin-dts": "^6.3.0",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@types/node": ">=10.4"
	},
	"peerDependenciesMeta": {
		"@types/node": {
			"optional": true
		}
	},
	"exports": {
		".": {
			"types": "./distribution/types/index.d.ts",
			"import": "./distribution/esm/index.mjs",
			"default": "./distribution/cjs/index.cjs"
		}
	}
}
